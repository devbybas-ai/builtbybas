# BuiltByBas Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local — it is in .gitignore

# === DATABASE ===
DATABASE_URL=           # PostgreSQL connection string (e.g., postgresql://user:pass@host:5432/builtbybas)

# === APPLICATION ===
NEXT_PUBLIC_SITE_URL=   # Public URL (e.g., https://builtbybas.com)
NODE_ENV=               # development | production
ADMIN_EMAIL=            # Admin email address for system notifications and auth (e.g., hello@builtbybas.com)

# === ANALYTICS ===
NEXT_PUBLIC_UMAMI_URL=  # Umami analytics script URL (e.g., https://analytics.builtbybas.com/script.js)
NEXT_PUBLIC_UMAMI_ID=   # Umami website ID (e.g., 1ff108d4-6963-4543-a838-a0d62a6ae979)

# === ENCRYPTION ===
ENCRYPTION_KEY=         # AES-256 key for PII encryption (generate with: openssl rand -base64 32)

# === EMAIL ===
RESEND_API_KEY=         # Resend API key (https://resend.com/api-keys)
EMAIL_FROM=             # Sender address (e.g., BuiltByBas <hello@builtbybas.com>)

# === PAYMENT (future) ===
# STRIPE_SECRET_KEY=    # Stripe secret key
# STRIPE_WEBHOOK_SECRET=# Stripe webhook signing secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # Stripe publishable key (client-safe)
